  "quality_gates": {
    "evidence_gate": {
      "label": "证据门",
      "checklist": [
        "关键判断是否有 A/B 级数据源支撑",
        "数据来源是否可追溯（含 URL 或报告名）",
        "统计数据是否标注采集日期",
        "存在争议时是否给出反例或边界条件"
      ],
      "threshold": "通过 >= 3/4 项"
    },
    "depth_gate": {
      "label": "深度门",
      "checklist": [
        "是否提供可复用框架/方法论（而不仅仅是工具推荐）",
        "是否含有适用边界/反例/异常情况处理",
        "是否展示了步骤化流程（从需求到交付的完整链路）",
        "是否提供可视化结构（流程图/框架图/清单/模板）"
      ],
      "threshold": "通过 >= 3/4 项"
    },
    "asset_gate": {
      "label": "资产门",
      "checklist": [
        "读者能否拿走一个模板、清单、字段表或 SOP",
        "资产是否具备实際可复用性（换一个人执行结果接近）",
        "是否标注了不能自动化/需要人工确认的环节",
        "资产有无版本号、更新时间、适用范围"
      ],
      "threshold": "通过 >= 3/4 项"
    },
    "business_gate": {
      "label": "商业门",
      "checklist": [
        "内容能否连接到咨询/订阅/模板包/陪跑服务的收费入口",
        "是否提供了收益测算或细节（而不是空泛估算）",
        "是否明确了目标用户群体和付费意愿",
        "风险提示是否充分（不承诺稳赚/股市）"
      ],
      "threshold": "通过 >= 3/4 项"
    }
  },
  "content_structures": {
    "deep_dive": [
      "先给结论（用户痛点 + 解决方案一句话概括）",
      "数据支撑（A/B 级证据，含来源和日期）",
      "方法论框架（可复用的操作系统，不是工具清单）",
      "可复用资产（模板/清单/字段表/SOP，含版本和更新机制）",
      "执行步骤（5-7 个具体到工具、命令、参数的动作）",
      "质量门禁自检（四道门通过状态）",
      "收费入口与风险提示"
    ],
    "workflow_sop": [
      "业务目标与输入标准",
      "处理步骤四段式（结构化原料→生成初稿→质量审查→资产沉淀）",
      "质量门禁检查清单",
      "异常处理与人工介入节点",
      "复盘指标与迭代方向"
    ]
  }
}
