    "purpose": "高端深度内容生成器的数据源与证据评级规则"
  },
  "evidence_rating_rules": {
    "A": {
      "label": "一手数据/官方财报/权威机构报告",
      "examples": [
        "企业年报/SEC 10-K",
        "行业协会统计报告",
        "官方平台公开数据（如 Substack 官方 blog）",
        "垂直 SaaS 厂商官方定价页"
      ],
      "weight": 1.0,
      "requirement": "深度报告中 A 级证据占比 >= 40%"
    },
    "B": {
      "label": "可靠媒体/知名机构分析",
      "examples": [
        "艾瑞咨询/易观分析报告",
        "a16z/Sequoia 投资理由公开文章",
        "TechCrunch/The Information 独家报道",
        "GitHub 官方 stars/下载量统计"
      ],
      "weight": 0.7,
      "requirement": "深度报告中 B 级证据占比 >= 30%"
    },
    "C": {
      "label": "社区讨论/个人经验/线上观察",
      "examples": [
        "Reddit/知乎/即刻 高赞回答",
        "实际操作者分享（含收入截图）",
        "电商平台销量/评论数据"
      ],
      "weight": 0.4,
      "requirement": "C 级证据必须配备 A/B 级证据交叉验证，单独使用不超过 20%"
    }
  },
